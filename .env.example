# ============================================================================
# AcademyDBMS 环境变量示例文件
# 使用方法: 复制此文件为 .env 并修改对应的值
# ============================================================================
#
# 对于 Docker 部署: docker compose up -d 会自动读取 .env
# 对于本地开发: 需要确保 server/.env 包含必要的变量
#

# ----------------------
# MySQL 数据库配置
# ----------------------
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=academy_database
MYSQL_USER=academy_user
MYSQL_PASSWORD=academy_pass_2025
MYSQL_ROOT_PASSWORD=root_pass_2025

# ----------------------
# 应用服务配置
# ----------------------
PORT=3001
NODE_ENV=production

# ----------------------
# 会话密钥 (建议修改为随机字符串)
# ----------------------
SESSION_SECRET=change_this_to_a_random_secret_string

# ----------------------
# AI 服务配置 (可选)
# ----------------------
# AI_API_KEY=your_ai_api_key_here
# AI_API_URL=https://api.example.com/v1/chat

# ----------------------
# CORS 配置
# ----------------------
# 开发环境允许的前端地址
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ----------------------
# Docker 镜像标签
# ----------------------
NODE_IMAGE=node:20-alpine
WEB_IMAGE_TAG=academydbms-web:latest